    <script>
        const RETAINED_RATE = 0.39; // pilot average lead→retained conversion with TrueVow
        function updateCalculator() {
            const bookings = parseInt(document.getElementById('calcBookings').value, 10) || 0;
            const manualCpa = parseFloat(document.getElementById('calcManualCpa').value) || 0;
            const netValue = parseFloat(document.getElementById('calcNetValue').value) || 0;

            const truevowCostPerBooking = 29;
            const manualSpend = bookings * manualCpa;
            const truevowSpend = bookings * truevowCostPerBooking;
            const savings = Math.max(manualSpend - truevowSpend, 0);
            const projectedRevenue = bookings * RETAINED_RATE * netValue;

            document.getElementById('calcBookingsValue').textContent = bookings;
            document.getElementById('calcManualSpend').textContent = formatCurrency(manualSpend);
            document.getElementById('calcTruevowSpend').textContent = formatCurrency(truevowSpend);
            document.getElementById('calcSavings').textContent = formatCurrency(savings);
            document.getElementById('calcRevenue').textContent = formatCurrency(projectedRevenue);
        }

        function formatCurrency(value) {
            return value.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
        }

        document.addEventListener('DOMContentLoaded', updateCalculator);
    </script>
