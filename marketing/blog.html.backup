<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog & Media Hub | TrueVow – Legal Automation, Ethics, and ROI</title>
    <meta name="description" content="Essential insights for law firm owners on ethical intake automation, zero-knowledge architecture, and maximizing profitability. Articles on LinkedIn, videos on YouTube.">
    <link rel="icon" type="image/svg+xml" href="../assets/logo.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://truevow.law/blog">
    <meta property="og:title" content="Blog & Media Hub | TrueVow – Legal Automation, Ethics, and ROI">
    <meta property="og:description" content="Essential insights for law firm owners on ethical intake automation, zero-knowledge architecture, and maximizing profitability.">
    <meta property="og:image" content="https://truevow.law/assets/social-share.png">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://truevow.law/blog">
    <meta property="twitter:title" content="Blog & Media Hub | TrueVow">
    <meta property="twitter:description" content="Essential insights for law firm owners on ethical intake automation and zero-knowledge architecture.">
    <meta property="twitter:image" content="https://truevow.law/assets/social-share.png">

    <!-- JSON-LD Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "TrueVow Blog & Media Hub",
      "description": "Legal tech insights for law firm owners",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "Article",
            "name": "Is Pay-Per-Intake Ethical? A 50-State Fee-Sharing Round-up",
            "description": "Why paying a vendor for a service is ethically sound, but paying a share of legal fees is a Model Rule 5.4 violation."
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@type": "VideoObject",
            "name": "Zero-Knowledge Walk-Through: What We Don't Store",
            "description": "A visual guide to our zero-retention policy and ephemeral processing that eliminates client data liability."
          }
        },
        {
          "@type": "ListItem",
          "position": 3,
          "item": {
            "@type": "Article",
            "name": "The Predictability Advantage: Deterministic Logic vs. Generative AI Risk",
            "description": "Why rule-based automation is the ethical, low-risk choice for client qualification over unpredictable LLMs."
          }
        }
      ]
    }
    </script>
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
            line-height: 1.6;
            color: #1a1a1a;
            background: #ffffff;
            padding-bottom: 80px; /* Space for sticky CTA bar */
        }
        
        /* HERO SECTION */
        .hero {
            background: linear-gradient(135deg, #0A2463 0%, #051633 100%);
            color: white;
            padding: 100px 20px 80px 20px;
            text-align: center;
        }
        
        .hero h1 {
            font-size: 54px;
            font-weight: 900;
            line-height: 1.2;
            margin-bottom: 24px;
            letter-spacing: -1px;
        }
        
        .hero p {
            font-size: 22px;
            color: rgba(255, 255, 255, 0.9);
            max-width: 800px;
            margin: 0 auto 40px auto;
            line-height: 1.6;
        }
        
        /* FILTER BAR */
        .filter-container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 24px;
        }
        
        .filter-bar {
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        .filter-btn {
            padding: 12px 32px;
            border-radius: 50px;
            border: 2px solid #E5E5E5;
            background: white;
            color: #666;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .filter-btn:hover {
            border-color: #0A2463;
            color: #0A2463;
            transform: translateY(-2px);
        }
        
        .filter-btn.active {
            background: #0A2463;
            color: white;
            border-color: #0A2463;
        }
        
        /* CONTENT GRID */
        .blog-grid {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 24px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 40px;
        }
        
        /* CONTENT CARD */
        .content-card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            height: 100%;
        }
        
        .content-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 32px rgba(10, 36, 99, 0.15);
        }
        
        .card-image {
            width: 100%;
            height: 240px;
            object-fit: cover;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        }
        
        .card-content {
            padding: 28px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        
        .card-type-badge {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 16px;
        }
        
        .badge-article {
            background: rgba(10, 36, 99, 0.1);
            color: #0A2463;
        }
        
        .badge-video {
            background: rgba(255, 0, 0, 0.1);
            color: #CC0000;
        }
        
        .card-title {
            font-size: 22px;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 12px;
            line-height: 1.3;
        }
        
        .card-teaser {
            font-size: 15px;
            color: #666;
            line-height: 1.6;
            margin-bottom: 20px;
            flex: 1;
        }
        
        .card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 16px;
            border-top: 1px solid #E5E5E5;
        }
        
        .card-date {
            font-size: 14px;
            color: #999;
        }
        
        .card-link {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #0A2463;
            font-weight: 600;
            font-size: 15px;
            text-decoration: none;
            transition: gap 0.3s ease;
        }
        
        .card-link:hover {
            gap: 10px;
        }
        
        .card-link.video-link {
            color: #CC0000;
        }
        
        .external-icon {
            width: 18px;
            height: 18px;
        }
        
        /* STICKY CTA BAR */
        .sticky-cta {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #0A2463;
            color: white;
            padding: 20px 24px;
            box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.15);
            z-index: 999;
            animation: slideUp 0.5s ease-out;
        }
        
        @keyframes slideUp {
            from {
                transform: translateY(100%);
            }
            to {
                transform: translateY(0);
            }
        }
        
        .sticky-cta-content {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }
        
        .sticky-cta-text {
            font-size: 18px;
            font-weight: 600;
        }
        
        .sticky-cta-buttons {
            display: flex;
            gap: 16px;
        }
        
        .sticky-cta-btn {
            padding: 12px 28px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 16px;
            text-decoration: none;
            transition: all 0.3s ease;
            white-space: nowrap;
        }
        
        .sticky-cta-btn.primary {
            background: white;
            color: #0A2463;
        }
        
        .sticky-cta-btn.primary:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 12px rgba(255, 255, 255, 0.3);
        }
        
        .sticky-cta-btn.secondary {
            background: transparent;
            color: white;
            border: 2px solid white;
        }
        
        .sticky-cta-btn.secondary:hover {
            background: white;
            color: #0A2463;
        }
        
        /* LEGAL FOOTER */
        .legal-disclaimer {
            max-width: 1200px;
            margin: 60px auto 40px auto;
            padding: 28px 32px;
            background: #F8F9FA;
            border-left: 4px solid #0A2463;
            border-radius: 8px;
        }
        
        .legal-disclaimer h4 {
            font-size: 16px;
            font-weight: 700;
            color: #0A2463;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .legal-disclaimer p {
            font-size: 14px;
            color: #666;
            line-height: 1.7;
        }
        
        /* RESPONSIVE */
        @media (max-width: 768px) {
            .hero h1 {
                font-size: 36px;
            }
            
            .hero p {
                font-size: 18px;
            }
            
            .blog-grid {
                grid-template-columns: 1fr;
            }
            
            .sticky-cta-content {
                flex-direction: column;
                text-align: center;
            }
            
            .sticky-cta-buttons {
                flex-direction: column;
                width: 100%;
            }
            
            .sticky-cta-btn {
                width: 100%;
            }
        }
        
        /* HIDDEN CLASS FOR FILTERING */
        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>

    <!-- STANDARDIZED NAVIGATION -->
    <nav style="position: sticky; top: 0; z-index: 1000; background: white; box-shadow: 0 2px 8px rgba(0,0,0,0.1); padding: 16px 0;">
        <div style="max-width: 1200px; margin: 0 auto; display: flex; align-items: center; padding: 0 24px; position: relative;">
            <!-- LEFT: Logo -->
            <a href="/marketing/index.html" style="display: flex; align-items: center; text-decoration: none; gap: 12px;">
                <img src="/assets/logo.svg" alt="TrueVow" style="height: 40px; width: auto;">
            </a>
            
            <!-- CENTER: Navigation Links -->
            <div style="display: flex; gap: 60px; align-items: center; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                <a href="/marketing/index.html" style="color: #333; text-decoration: none; font-size: 16px; font-weight: 500; transition: color 0.3s;" onmouseover="this.style.color='#0A2463'" onmouseout="this.style.color='#333'">Home</a>
                <a href="/marketing/how-it-works.html" style="color: #333; text-decoration: none; font-size: 16px; font-weight: 500; transition: color 0.3s;" onmouseover="this.style.color='#0A2463'" onmouseout="this.style.color='#333'">How It Works</a>
                <a href="/marketing/pricing.html" style="color: #333; text-decoration: none; font-size: 16px; font-weight: 500; transition: color 0.3s;" onmouseover="this.style.color='#0A2463'" onmouseout="this.style.color='#333'">Pricing</a>
                <a href="/marketing/county-cap.html" style="color: #333; text-decoration: none; font-size: 16px; font-weight: 500; transition: color 0.3s;" onmouseover="this.style.color='#0A2463'" onmouseout="this.style.color='#333'">33% Cap</a>
                <a href="/marketing/profitability.html" style="color: #333; text-decoration: none; font-size: 16px; font-weight: 500; transition: color 0.3s;" onmouseover="this.style.color='#0A2463'" onmouseout="this.style.color='#333'">ROI</a>
            </div>
            
            <!-- RIGHT: CTA Button -->
            <a href="/marketing/apply.html" style="margin-left: auto; background: #0A2463; color: white; padding: 12px 28px; border-radius: 8px; font-size: 16px; font-weight: 600; text-decoration: none; transition: all 0.3s; display: inline-flex; align-items: center; gap: 8px;" onmouseover="this.style.background='#0D2F7E'" onmouseout="this.style.background='#0A2463'">
                Apply Now →
            </a>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <section class="hero">
        <h1>Stop Billing Admin Time.<br>Start Billing Legal Time.</h1>
        <p>The TrueVow Guide to Ethical Automation, Zero-Knowledge Security,<br>and Profitable Practice for Law Firm Owners.</p>
    </section>

    <!-- FILTER BAR -->
    <div class="filter-container">
        <div class="filter-bar">
            <button class="filter-btn active" data-filter="all">All Content</button>
            <button class="filter-btn" data-filter="article">📄 Articles (LinkedIn)</button>
            <button class="filter-btn" data-filter="video">🎥 Videos (YouTube)</button>
        </div>
    </div>

    <!-- CONTENT GRID -->
    <!-- Blog content is loaded dynamically from Supabase via js/blog-content.js -->
    <div class="blog-grid" id="blog-grid">
        <!-- Content will be rendered here automatically -->
    </div>

    <!-- LEGAL DISCLAIMER -->
    <div class="legal-disclaimer" style="margin: 60px 24px 40px 24px;">
        <h4>⚠️ Compliance Note</h4>
        <p><strong>External links are provided for informational and educational purposes.</strong> TrueVow Global Technologies FZ-LLC (UAE) is not responsible for the content, privacy policies, or legal claims made on external platforms (LinkedIn, YouTube). All content is subject to the provisions of the <a href="../legal/terms.html" style="color: #0A2463; font-weight: 600;">TrueVow Terms of Service</a> and <a href="../legal/msa.html" style="color: #0A2463; font-weight: 600;">Master Services Agreement (MSA)</a>. This content is for informational purposes only and does not constitute legal advice. Consult your state bar association for guidance on legal tech compliance in your jurisdiction.</p>
    </div>

    <!-- STICKY CTA BAR -->
    <div class="sticky-cta">
        <div class="sticky-cta-content">
            <div class="sticky-cta-text">
                👋 Automate Your Intake Ethically & Predictably
            </div>
            <div class="sticky-cta-buttons">
                <a href="apply.html" class="sticky-cta-btn primary">Book a Demo</a>
                <a href="pricing.html" class="sticky-cta-btn secondary">Calculate ROI</a>
            </div>
        </div>
    </div>

    <!-- STANDARDIZED FOOTER -->
    <footer style="background: #1A1A1A; color: white; padding: 60px 20px 120px 20px; text-align: center;">
        <div style="max-width: 1200px; margin: 0 auto;">
            <!-- Logo -->
            <img src="/assets/logo.svg" alt="TrueVow" style="height: 50px; width: auto; margin-bottom: 24px; opacity: 0.9;">
            
            <p style="font-size: 16px; color: #999; margin-bottom: 40px; line-height: 1.6;">
                More clients. More money. More time with your family.<br>
                All without risking your license.
            </p>
            
            <!-- 3-Column Links -->
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; max-width: 900px; margin: 40px auto; text-align: center;">
                <div>
                    <h4 style="color: #FFFFFF; font-size: 16px; font-weight: 700; margin-bottom: 16px; letter-spacing: 1px;">PRODUCT</h4>
                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        <a href="/marketing/how-it-works.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">How It Works</a>
                        <a href="/marketing/pricing.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">Pricing</a>
                        <a href="/marketing/profitability.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">ROI &amp; Profitability</a>
                        <a href="/marketing/county-cap.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">33% County Cap</a>
                    </div>
                </div>
                <div>
                    <h4 style="color: #FFFFFF; font-size: 16px; font-weight: 700; margin-bottom: 16px; letter-spacing: 1px;">RESOURCES</h4>
                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        <a href="/marketing/blog.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">Blog</a>
                        <a href="/marketing/case-studies.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">Case Studies</a>
                        <a href="/marketing/partner.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">Partner Program</a>
                        <a href="/marketing/affiliate.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">Affiliate Program</a>
                    </div>
                </div>
                <div>
                    <h4 style="color: #FFFFFF; font-size: 16px; font-weight: 700; margin-bottom: 16px; letter-spacing: 1px;">COMPANY</h4>
                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        <a href="/marketing/about.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">About Us</a>
                        <a href="/marketing/careers.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">Careers</a>
                        <a href="/marketing/press.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">Press</a>
                        <a href="/marketing/apply.html" style="color: #999; text-decoration: none; font-size: 15px; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">Contact</a>
                    </div>
                </div>
            </div>
            
            <!-- Legal Links -->
            <div style="display: flex; justify-content: center; align-items: center; gap: 16px; margin-top: 40px; flex-wrap: wrap; font-size: 14px;">
                <a href="/legal/privacy.html" style="color: #999; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">Privacy Policy</a>
                <span style="color: #555;">|</span>
                <a href="/legal/terms.html" style="color: #999; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">Terms of Service</a>
                <span style="color: #555;">|</span>
                <a href="/legal/msa.html" style="color: #999; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">MSA</a>
                <span style="color: #555;">|</span>
                <a href="/legal/bar-compliance.html" style="color: #999; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#FFFFFF'" onmouseout="this.style.color='#999'">Bar Compliance</a>
            </div>
            
            <!-- Disclaimer -->
            <p style="font-size: 11pt; color: #555; margin-top: 32px; line-height: 1.8; max-width: 900px; margin-left: auto; margin-right: auto; padding-bottom: 60px;">
                © 2026 TrueVow Technologies. All rights reserved. TrueVow is a brand of TrueVow Global Technologies FZ-LLC (UAE), a subsidiary of TrueVow Global Holdings LLC (Nevis). TrueVow (USA) Inc. (Wyoming) provides passive marketing only and does not handle contracts or operations. All contracts are with TrueVow Global Technologies FZ-LLC (UAE). Technology and IP held by TrueVow Global Holdings LLC (Nevis). We are not a law firm and do not provide legal advice. By using our services, you acknowledge that TrueVow operates as a technology and services provider only.
            </p>
        </div>
    </footer>

    <!-- BLOG CONTENT ENGINE -->
    <!-- This script fetches blog content from Supabase and renders it dynamically -->
    <!-- Configuration: Update SUPABASE_URL and SUPABASE_ANON_KEY in js/blog-content.js -->
    <script src="../js/blog-content.js"></script>
    
    <!-- Note: Filter functionality is now handled by blog-content.js -->
    <!-- The script automatically initializes on page load and handles filtering -->

</body>
</html>
