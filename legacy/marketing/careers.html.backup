    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            line-height: 1.6;
            color: #1A1A1A;
            background: #FFFFFF;
        }
        
        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 80px 24px;
        }
        
        h1 {
            font-size: 48px;
            font-weight: 800;
            color: #0A2463;
            margin-bottom: 24px;
            text-align: center;
            line-height: 1.2;
        }
        
        h2 {
            font-size: 36px;
            font-weight: 700;
            color: #0A2463;
            margin: 60px 0 24px;
        }
        
        h3 {
            font-size: 24px;
            font-weight: 700;
            color: #1A1A1A;
            margin: 32px 0 16px;
        }
        
        p {
            font-size: 18px;
            line-height: 1.8;
            color: #666;
            margin-bottom: 24px;
        }
        
        .subtitle {
            font-size: 22px;
            color: #666;
            text-align: center;
            margin-bottom: 40px;
            font-weight: 500;
        }
        
        .highlight {
            background: #FFF1F2;
            padding: 32px;
            border-left: 4px solid #DC2626;
            border-radius: 8px;
            margin: 40px 0;
        }
        
        .highlight p {
            color: #B91C1C;
            font-weight: 600;
            font-size: 20px;
            margin-bottom: 0;
        }
        
        .card {
            background: white;
            padding: 32px;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            margin-bottom: 24px;
        }
        
        .card h3 {
            color: #0A2463;
            margin-top: 0;
        }
        
        .role-card {
            background: linear-gradient(135deg, #0A2463 0%, #1a3a8a 100%);
            color: white;
            padding: 40px;
            border-radius: 16px;
            margin-bottom: 32px;
        }
        
        .role-card h3 {
            color: white;
            font-size: 28px;
            margin-bottom: 16px;
        }
        
        .role-card p {
            color: #E5E5E5;
            margin-bottom: 20px;
        }
        
        .role-card ul {
            color: #E5E5E5;
            line-height: 2;
            margin-left: 24px;
        }
        
        .role-card strong {
            color: #FFD700;
        }
        
        .cta-button {
            display: inline-block;
            background: #0A2463;
            color: white;
            padding: 16px 40px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 700;
            font-size: 18px;
            transition: all 0.3s;
            text-align: center;
        }
        
        .cta-button:hover {
            background: #0D2F7E;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(10,36,99,0.3);
        }
        
        ul {
            margin-left: 24px;
            line-height: 2;
            color: #666;
        }
        
        .values-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 24px;
            margin: 40px 0;
        }
        
        .value-card {
            background: #F8F9FA;
            padding: 32px;
            border-radius: 12px;
            text-align: center;
        }
        
        .value-icon {
            font-size: 48px;
            margin-bottom: 16px;
        }
        
        .value-card h3 {
            font-size: 20px;
            margin: 16px 0 12px;
        }
        
        .value-card p {
            font-size: 16px;
            margin-bottom: 0;
            color: #555;
        }
        
        .quote-box {
            background: #F8F9FA;
            padding: 32px;
            border-left: 4px solid #10B981;
            border-radius: 8px;
            font-style: italic;
            margin: 40px 0;
        }
        
        .quote-box p {
            color: #1A1A1A;
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 12px;
        }
        
        .quote-author {
            font-size: 16px;
            color: #999;
            font-style: italic;
        }
